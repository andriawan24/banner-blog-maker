# Database (Postgres). Required for accounts + saved banner configs.
DATABASE_URL="postgresql://user:password@localhost:5432/banner_maker"

# Auth.js (NextAuth). NEXTAUTH_URL should match the app's public origin.
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Password assigned to users created by `pnpm db:seed` (prisma/seed.ts).
SEEDER_USER_PASSWORD="change-me-before-seeding"

# S3-compatible object storage for image uploads used inside banners.
S3_BUCKET="your-bucket"
S3_ENDPOINT="https://s3.example.com"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL="https://s3.example.com/your-bucket"
S3_UPLOAD_PREFIX="uploads"
